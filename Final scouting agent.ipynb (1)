{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1VNDiIIjA5Swffjou-yPKwGiNt45UrTIG","timestamp":1777113611893}],"authorship_tag":"ABX9TyPAjt6Xau0sXXaHyrKjQ1hT"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["!pip install groq -q"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"pDZXra4SIgdS","executionInfo":{"status":"ok","timestamp":1777131207374,"user_tz":-330,"elapsed":5890,"user":{"displayName":"Abinash Das","userId":"00464583311813293808"}},"outputId":"b660ab47-5605-4c27-f170-f742e6b3364d"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[?25l   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m0.0/142.3 kB\u001b[0m \u001b[31m?\u001b[0m eta \u001b[36m-:--:--\u001b[0m\r\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m142.3/142.3 kB\u001b[0m \u001b[31m10.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25h"]}]},{"cell_type":"code","source":["\n","from groq import Groq\n","\n","client = Groq(api_key=\"YOUR_GROQ_API_KEY_HERE\")\n","\n","jd = \"Backend Engineer, 3+ years, Python, REST APIs, PostgreSQL, Docker\"\n","\n","candidates = [\n","    \"Sarah Chen, 2.5 years, Python Flask REST APIs SQL Git\",\n","    \"David Miller, 3 years, Python Django REST APIs SQL Git\",\n","    \"Anya Sharma, 2 years, Python FastAPI SQL Docker Git\",\n","    \"Michael Davis, 4 years, Python Flask PostgreSQL REST APIs Git\",\n","    \"Emily Wong, 3.5 years, Python Pandas SQL REST APIs Git\",\n","]\n","\n","prompt = f\"\"\"\n","You are a recruiter. For each candidate, give Match Score and Interest Score (0-100).\n","\n","Job: {jd}\n","\n","Candidates:\n","1. {candidates[0]}\n","2. {candidates[1]}\n","3. {candidates[2]}\n","4. {candidates[3]}\n","5. {candidates[4]}\n","\n","Reply in this exact format:\n","1. Match: XX, Interest: XX\n","2. Match: XX, Interest: XX\n","3. Match: XX, Interest: XX\n","4. Match: XX, Interest: XX\n","5. Match: XX, Interest: XX\n","\"\"\"\n","\n","response = client.chat.completions.create(\n","    model=\"llama-3.3-70b-versatile\",\n","    messages=[{\"role\": \"user\", \"content\": prompt}]\n",")\n","\n","print(response.choices[0].message.content)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Ujp_dXJIIjQG","executionInfo":{"status":"ok","timestamp":1777131209838,"user_tz":-330,"elapsed":2459,"user":{"displayName":"Abinash Das","userId":"00464583311813293808"}},"outputId":"bbf40f55-bb29-41e1-86df-d57b6fdee746"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["1. Match: 80, Interest: 70\n","2. Match: 90, Interest: 80\n","3. Match: 70, Interest: 60\n","4. Match: 95, Interest: 90\n","5. Match: 80, Interest: 70\n"]}]},{"cell_type":"code","source":["import re\n","\n","output = response.choices[0].message.content\n","\n","names = [\n","    \"Sarah Chen\",\n","    \"David Miller\",\n","    \"Anya Sharma\",\n","    \"Michael Davis\",\n","    \"Emily Wong\"\n","]\n","\n","results = []\n","lines = output.strip().split(\"\\n\")\n","for i, line in enumerate(lines):\n","    numbers = re.findall(r'\\d+', line)\n","    if len(numbers) >= 2:\n","        results.append({\n","            \"Name\": names[i],\n","            \"Match\": int(numbers[0]),\n","            \"Interest\": int(numbers[1])\n","        })\n","\n","results.sort(key=lambda x: x['Match'], reverse=True)\n","\n","print(\"\\n===== FINAL RANKED SHORTLIST =====\")\n","print(f\"{'Rank':<6} {'Name':<20} {'Match Score':<15} {'Interest Score'}\")\n","print(\"-\" * 55)\n","for i, r in enumerate(results, 1):\n","    print(f\"{i:<6} {r['Name']:<20} {r['Match']:<15} {r['Interest']}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"QrFAoU8XKK44","executionInfo":{"status":"ok","timestamp":1777131209863,"user_tz":-330,"elapsed":22,"user":{"displayName":"Abinash Das","userId":"00464583311813293808"}},"outputId":"1f1665a3-fcbf-48b8-c8f1-9fb4ab0c8444"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","===== FINAL RANKED SHORTLIST =====\n","Rank   Name                 Match Score     Interest Score\n","-------------------------------------------------------\n","1      Emily Wong           5               80\n","2      Michael Davis        4               95\n","3      Anya Sharma          3               70\n","4      David Miller         2               90\n","5      Sarah Chen           1               80\n"]}]},{"cell_type":"code","source":["def simulate_conversation(candidate, jd):\n","    prompt = f\"\"\"\n","    Simulate a short recruiter-candidate chat (3 messages each).\n","    Recruiter is reaching out about the job.\n","    Candidate responds naturally showing their interest level.\n","\n","    Job: {jd}\n","    Candidate: {candidate}\n","\n","    Format:\n","    Recruiter: ...\n","    Candidate: ...\n","    Recruiter: ...\n","    Candidate: ...\n","    Recruiter: ...\n","    Candidate: ...\n","\n","    End with:\n","    Interest Score: XX/100\n","    \"\"\"\n","    response = client.chat.completions.create(\n","        model=\"llama-3.3-70b-versatile\",\n","        messages=[{\"role\": \"user\", \"content\": prompt}]\n","    )\n","    return response.choices[0].message.content\n","\n","# Test with one candidate\n","print(simulate_conversation(candidates[0], jd))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"08WMXQMWLB9G","executionInfo":{"status":"ok","timestamp":1777131212330,"user_tz":-330,"elapsed":2466,"user":{"displayName":"Abinash Das","userId":"00464583311813293808"}},"outputId":"eaec9cac-182d-4ef8-e703-ab165c875850"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Recruiter: Hi Sarah, I came across your profile and noticed your experience with Python and REST APIs. We're currently looking for a Backend Engineer with similar skills, and I thought you might be a great fit. The role involves working with Python, REST APIs, PostgreSQL, and Docker. Would you be interested in learning more about the position?\n","\n","Candidate: Hi, thanks for reaching out. I'm definitely interested in learning more about the role, although I noticed the job requires 3+ years of experience and I have about 2.5 years. My experience is mostly with Python Flask and SQL, but I've worked with REST APIs and Git. I'm eager to learn and grow, so I'd love to hear more about the position and see if it's a good fit.\n","\n","Recruiter: That's completely understandable, Sarah. We do consider candidates who are close to the experience requirement, and your skills in Python Flask and REST APIs are definitely relevant. The team is looking for someone who is willing to learn and adapt, and it sounds like you might be a good fit. Can you tell me a bit more about your experience with REST APIs and how you've used them in your previous projects?\n","\n","Candidate: In my current role, I've worked on building multiple REST APIs using Flask, and I've also consumed external APIs in some of my side projects. I've gained a good understanding of API design principles and have experience with HTTP methods, authentication, and error handling. I'm excited about the opportunity to work with a more complex tech stack like the one you described, especially with PostgreSQL and Docker, which I've been wanting to learn more about.\n","\n","Recruiter: That sounds great, Sarah. It's excellent that you have hands-on experience with REST APIs and a willingness to learn more about our tech stack. We're a collaborative team, and we provide opportunities for professional growth and development. If you're still interested, I'd love to schedule a call to discuss the role in more detail and answer any questions you may have.\n","\n","Candidate: That sounds awesome, thank you for the opportunity. I'd definitely like to schedule a call and learn more about the team and the role. I'm looking forward to hearing more about the company culture and how this position contributes to the organization's goals. Please let me know a few dates and times that work for you, and I'll make sure to adjust my schedule accordingly.\n","\n","Interest Score: 85/100\n"]}]},{"cell_type":"code","source":["import re\n","\n","print(\"=\"*60)\n","print(\"   AI TALENT SCOUTING & ENGAGEMENT AGENT\")\n","print(\"=\"*60)\n","\n","names = [\"Sarah Chen\", \"David Miller\", \"Anya Sharma\", \"Michael Davis\", \"Emily Wong\"]\n","\n","final_results = []\n","\n","for i, candidate in enumerate(candidates):\n","    print(f\"\\nProcessing {names[i]}...\")\n","\n","    # Get match score with reason\n","    match_resp = client.chat.completions.create(\n","        model=\"llama-3.3-70b-versatile\",\n","        messages=[{\"role\": \"user\", \"content\": f\"\"\"\n","        Score this candidate for the job 0-100 based on skills match.\n","        Reply in this exact format only:\n","        Match Score: XX\n","        Reason: one sentence why\n","\n","        Job: {jd}\n","        Candidate: {candidate}\n","        \"\"\"}]\n","    )\n","    match_text = match_resp.choices[0].message.content\n","    match_num = re.search(r'Match Score:\\s*(\\d+)', match_text)\n","    match_reason = re.search(r'Reason:\\s*(.+)', match_text)\n","    match_score = int(match_num.group(1)) if match_num else 0\n","    reason = match_reason.group(1).strip() if match_reason else \"\"\n","\n","    # Get conversation + interest score\n","    interest_resp = client.chat.completions.create(\n","        model=\"llama-3.3-70b-versatile\",\n","        messages=[{\"role\": \"user\", \"content\": f\"\"\"\n","        Simulate a 3 exchange recruiter-candidate conversation.\n","        At the very end write exactly:\n","        Interest Score: XX\n","        Where XX is a number between 0 and 100.\n","\n","        Job: {jd}\n","        Candidate: {candidate}\n","        \"\"\"}]\n","    )\n","    conv_text = interest_resp.choices[0].message.content\n","    interest_matches = re.findall(r'Interest Score:\\s*(\\d+)', conv_text)\n","    interest_score = int(interest_matches[-1]) if interest_matches else 0\n","\n","    final_score = round(0.7 * match_score + 0.3 * interest_score)\n","\n","    final_results.append({\n","        \"Name\": names[i],\n","        \"Match\": match_score,\n","        \"Interest\": interest_score,\n","        \"Final\": final_score,\n","        \"Reason\": reason,\n","        \"Conversation\": conv_text\n","    })\n","\n","# Print all conversations first\n","print(\"\\n\" + \"=\"*60)\n","print(\"         CANDIDATE CONVERSATIONS\")\n","print(\"=\"*60)\n","for r in final_results:\n","    print(f\"\\n--- {r['Name']} ---\")\n","    print(r['Conversation'])\n","    print()\n","\n","# Sort and print final table\n","final_results.sort(key=lambda x: x['Final'], reverse=True)\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"           FINAL RANKED SHORTLIST\")\n","print(\"=\"*70)\n","print(f\"{'Rank':<6} {'Name':<20} {'Match':<8} {'Interest':<10} {'Final':<8} Reason\")\n","print(\"-\"*70)\n","for i, r in enumerate(final_results, 1):\n","    print(f\"{i:<6} {r['Name']:<20} {r['Match']:<8} {r['Interest']:<10} {r['Final']:<8} {r['Reason']}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tY7Hde_FTpO2","executionInfo":{"status":"ok","timestamp":1777131770676,"user_tz":-330,"elapsed":9464,"user":{"displayName":"Abinash Das","userId":"00464583311813293808"}},"outputId":"a6d21e5a-a330-4e9a-ca22-ebea54984cf8"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","   AI TALENT SCOUTING & ENGAGEMENT AGENT\n","============================================================\n","\n","Processing Sarah Chen...\n","\n","Processing David Miller...\n","\n","Processing Anya Sharma...\n","\n","Processing Michael Davis...\n","\n","Processing Emily Wong...\n","\n","============================================================\n","         CANDIDATE CONVERSATIONS\n","============================================================\n","\n","--- Sarah Chen ---\n","Exchange 1:\n","Recruiter: Hi Sarah, thank you for considering our company. Can you tell me a little about your background and how you think your skills align with the Backend Engineer position?\n","Candidate: Absolutely. I have about 2.5 years of experience working with Python and Flask to build REST APIs. I've also used SQL for database management and Git for version control. I'm excited about the opportunity to work with PostgreSQL and Docker, as I've heard great things about them.\n","\n","Exchange 2:\n","Recruiter: That's great to hear, Sarah. One of the key requirements for this position is experience with Python, which you have. However, you're a bit short on the years of experience we're looking for. Can you tell me about a particularly challenging project you've worked on and how you overcame any obstacles that came up?\n","Candidate: One project that comes to mind is when I had to optimize the performance of a Flask API that was handling a high volume of requests. I was able to use caching and database indexing to improve the response times, and I learned a lot about how to troubleshoot and resolve performance issues.\n","\n","Exchange 3:\n","Recruiter: I'm impressed by your problem-solving skills, Sarah. As a Backend Engineer at our company, you'll be working on a team to design and implement scalable and efficient backend systems. You'll also have the opportunity to learn and grow with our team. What are your thoughts on the position, and do you have any questions for me?\n","Candidate: I'm really interested in the position and think I could make a great fit. I do have one question - can you tell me more about the team I'd be working with and what a typical day would look like in this role?\n","\n","Interest Score: 80\n","\n","\n","--- David Miller ---\n","Exchange 1:\n","Recruiter: Hi David, thanks for considering our company. Can you tell me a little about your background and how you think your skills align with the backend engineer position we have available?\n","Candidate: Absolutely. With 3 years of experience in Python and Django, I've had the opportunity to work on several projects involving REST APIs and SQL databases. I'm excited about the prospect of working with PostgreSQL and Docker, as I've had some experience with similar technologies in the past.\n","\n","Exchange 2:\n","Recruiter: That's great to hear, David. Can you walk me through your experience with REST APIs? Have you worked on any projects that involved designing and implementing APIs from scratch?\n","Candidate: Yes, in my current role, I've worked on several projects where I've designed and implemented REST APIs using Django. I've also had experience with API documentation and testing, which I believe is essential for ensuring the quality and reliability of the APIs. I'm confident that my experience in this area would be a good fit for the position.\n","\n","Exchange 3:\n","Recruiter: Excellent, David. Finally, can you tell me what you're looking for in a role and why you're interested in this position? What do you hope to achieve in this position, and how do you think your skills and experience make you a strong fit?\n","Candidate: I'm looking for a challenging role that will allow me to grow and develop as a backend engineer. I'm interested in this position because of the opportunity to work with a talented team and contribute to the development of high-quality software products. I believe my experience with Python, Django, and REST APIs makes me a strong fit for the position, and I'm excited about the prospect of working with PostgreSQL and Docker.\n","\n","Interest Score: 85\n","\n","\n","--- Anya Sharma ---\n","Exchange 1:\n","Recruiter: Hi Anya, thank you for considering our company. Can you tell me a little about your background and how you think your skills align with the Backend Engineer position we have available?\n","Candidate: Absolutely. With 2 years of experience in Python, I've worked on several projects using FastAPI and SQL. I've also gained experience with Docker and Git. Although I don't have direct experience with REST APIs or PostgreSQL, I'm eager to learn and adapt to new technologies.\n","\n","Exchange 2:\n","Recruiter: That's great to hear, Anya. Since you don't have direct experience with REST APIs or PostgreSQL, can you walk me through how you would approach learning these new technologies and applying them to our specific job requirements?\n","Candidate: I believe in hands-on learning, so I would start by working on personal projects that incorporate REST APIs and PostgreSQL. I'd also take online courses to fill any knowledge gaps and make sure I understand the best practices for implementing these technologies in a production environment.\n","\n","Exchange 3:\n","Recruiter: Excellent attitude, Anya. How do you think your experience with FastAPI and SQL can be leveraged in our environment, and what do you think you can bring to our team as a Backend Engineer?\n","Candidate: I think my experience with FastAPI can be easily translated to working with REST APIs, as both involve building efficient and scalable APIs. Additionally, my understanding of SQL can be applied to learning PostgreSQL. I'm a strong team player, and I'm excited about the opportunity to contribute to the company's growth and learn from the team's experiences.\n","\n","Interest Score: 80\n","\n","\n","--- Michael Davis ---\n","Exchange 1:\n","Recruiter: Hi Michael, thank you for considering our company. Can you tell me a little about your background and how you think your skills align with the Backend Engineer position we have available?\n","Candidate: Absolutely. With 4 years of experience in Python, I've developed a strong foundation in building REST APIs and working with PostgreSQL. I've also used Git for version control. I'm excited about the opportunity to work with Docker, which I've been wanting to learn more about.\n","\n","Exchange 2:\n","Recruiter: That's great to hear, Michael. Can you give me an example of a particularly challenging project you've worked on and how you overcame any obstacles that came up?\n","Candidate: One project that comes to mind is when I had to optimize the performance of a REST API that was experiencing high latency. I used profiling tools to identify the bottleneck and then implemented caching and database indexing to improve the performance. The outcome was a significant reduction in latency, and the client was very satisfied.\n","\n","Exchange 3:\n","Recruiter: Excellent problem-solving skills, Michael. Finally, what are your long-term career goals, and how do you see this Backend Engineer position fitting into your overall career aspirations?\n","Candidate: My goal is to continue growing as a technical expert and eventually move into a leadership role where I can mentor and guide other engineers. I believe this position will provide me with the opportunities to work on complex projects, learn from experienced colleagues, and take on additional responsibilities that will help me achieve my goals.\n","\n","Interest Score: 90\n","\n","\n","--- Emily Wong ---\n","Exchange 1:\n","Recruiter: Hi Emily, thanks for considering our company. Can you tell me a little about your background and how you think your skills align with the Backend Engineer role we have available?\n","Candidate: Absolutely. With 3.5 years of experience, I've developed a strong foundation in Python, Pandas, and SQL. I've also worked extensively with REST APIs and Git. I'm excited about the opportunity to work with PostgreSQL and Docker, as I believe my existing skills will translate well.\n","\n","Exchange 2:\n","Recruiter: That's great to hear, Emily. Can you walk me through your experience with REST APIs? Have you worked on any projects that involved designing and implementing APIs from scratch?\n","Candidate: Yes, in my current role, I've designed and implemented several REST APIs using Python. I've worked on both the backend and frontend sides, ensuring seamless communication between the two. I'm confident in my ability to create well-structured, efficient APIs that meet the needs of our application.\n","\n","Exchange 3:\n","Recruiter: Excellent, Emily. Finally, what are your long-term career goals, and how do you see this Backend Engineer role fitting into your overall career aspirations?\n","Candidate: I'm looking to continue growing as a software engineer, taking on more complex challenges and responsibilities. This role at your company aligns with my goals, as it offers the opportunity to work with a talented team, expand my skill set, and contribute to the development of high-quality software applications. I'm excited about the prospect of joining your team and making meaningful contributions.\n","\n","Interest Score: 85\n","\n","\n","======================================================================\n","           FINAL RANKED SHORTLIST\n","======================================================================\n","Rank   Name                 Match    Interest   Final    Reason\n","----------------------------------------------------------------------\n","1      Michael Davis        90       90         90       The candidate's skills in Python, REST APIs, and PostgreSQL closely match the job requirements, with the only notable absence being Docker.\n","2      David Miller         80       85         82       David Miller's experience with Python, Django, and REST APIs is a strong match, but the job requires PostgreSQL and Docker, which are not listed in his skills.\n","3      Emily Wong           80       85         82       Emily Wong's skills in Python, REST APIs, and SQL partially match the job requirements, but she lacks direct experience with PostgreSQL and Docker.\n","4      Anya Sharma          80       80         80       Anya Sharma has relevant experience with Python, Docker, and SQL, but lacks experience with REST APIs and PostgreSQL, and has less than the required 3 years of experience.\n","5      Sarah Chen           70       80         73       The candidate has relevant experience with Python, REST APIs, and SQL, but falls short on the exact requirements of 3+ years of experience, PostgreSQL, and Docker.\n"]}]}]}